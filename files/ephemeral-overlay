#!/bin/bash

set -e

# Use mimalloc only for commands that process large datasets or run for extended periods
# rsync: May sync large directory trees with many files
# find: May traverse deep filesystem hierarchies with thousands of entries
# inotifywait: Long-lived daemon with frequent small allocations from event stream
# Short-lived commands (lsof, awk, grep, rm, fuser) are NOT preloaded as the
# LD_PRELOAD library loading overhead exceeds any allocation performance benefit
if [ -r /usr/lib/libmimalloc.so ]; then
    RSYNC="env LD_PRELOAD=/usr/lib/libmimalloc.so rsync"
    FIND="env LD_PRELOAD=/usr/lib/libmimalloc.so find"
    INOTIFYWAIT="env LD_PRELOAD=/usr/lib/libmimalloc.so inotifywait"
else
    RSYNC="rsync"
    FIND="find"
    INOTIFYWAIT="inotifywait"
fi

OVERLAY_BASE="/ram_overlay"
STATE_FILE="/var/run/ramoverlay.state"
DAEMON_PIDFILE="/var/run/ramoverlay-daemon.pid"
LOG_FILE="/var/log/ramoverlay.log"
INOTIFY_QUEUE="/var/run/ramoverlay-inotify.queue"
INOTIFY_PIDFILE="/var/run/ramoverlay-inotify.pid"

TMP_SIZE="5G"
VAR_TMP_SIZE="1G"
VAR_CACHE_SIZE="2G"
USER_CACHE_SIZE="2G"
OVERLAY_BASE_SIZE="90%"   # tmpfs supports a %-of-physical-RAM size directly

CLEAN_INTERVAL=30
STALE_MINUTES=5

# How often to sync RAM -> disk while a session stays open, in addition to
# the sync that always happens at logout/shutdown. 0 disables. This is cheap
# now that sync_changes() actually does incremental syncs (see audit notes
# below) -- it only costs real work when something changed since the last
# pass, so it's safe to leave on.
SYNC_INTERVAL=300

PERSIST_ROOT="/persist"

BIND_MOUNTED_VAR_CACHE=(pacman)
BIND_MOUNTED_USER_CACHE=(nvidia mesa_shader_cache mesa_shader_cache_db)

# Directories to overlay (will be mounted in RAM and actually used)
# NOTE: Exclude large package/runtime directories to save RAM
# NOTE: entries must not be nested (no entry may be a parent/child of
# another) -- the inotify queue filtering in sync_changes() matches by
# literal path prefix and assumes OVERLAY_DIRS entries don't overlap.
OVERLAY_DIRS=(
    "/etc"
    "/var/log"
    # DO NOT OVERLAY THESE - TOO LARGE:
    # "/var/lib"      # Contains flatpak (12GB+), databases, etc.
    # "/opt"          # Can be 2GB+ with large applications
    # "/usr/local"
)

# Directories to completely exclude from overlay sync AND from the eager
# upper-layer pre-population copy-up (see create_directory_overlay). An
# entry only has any effect if it falls under one of OVERLAY_DIRS above --
# "/var/lib/systemd" below currently doesn't (only /etc and /var/log are
# overlaid), so it's a no-op today; left in place in case /var/lib is
# overlaid later.
EXCLUDED_FROM_SYNC=(
    "/var/lib/systemd"
    "/var/log/journal"
)

USE_LSOF=0
USE_FUSER=0
if command -v lsof >/dev/null 2>&1; then
    USE_LSOF=1
elif command -v fuser >/dev/null 2>&1; then
    USE_FUSER=1
fi

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        log "ERROR: Must be run as root"
        exit 1
    fi
}

is_active() {
    [ -f "$STATE_FILE" ] && grep -qxE "active|degraded" "$STATE_FILE"
}

is_degraded() {
    [ -f "$STATE_FILE" ] && grep -qx "degraded" "$STATE_FILE"
}

# Builds rsync --exclude= flags for any EXCLUDED_FROM_SYNC entry that falls
# under $1, expressed relative to $1. Shared by create_directory_overlay's
# pre-population copy-up and sync_changes's write-back, so both agree on
# what "excluded" means instead of the same matching logic being maintained
# in two places.
compute_exclude_opts() {
    local dir="$1"
    local excl
    for excl in "${EXCLUDED_FROM_SYNC[@]}"; do
        if [[ "$excl" == "$dir"* ]]; then
            echo "--exclude=${excl#"$dir"/}"
        fi
    done
}

# --- In-use file detection --------------------------------------------------
#
# Checking whether a candidate file is open used to mean forking lsof/fuser
# (or, lacking both, walking every /proc/*/fd symlink with a separate forked
# `readlink` call) FOR EACH candidate file individually. On a cleanup pass
# with a few hundred stale files that's a few hundred forks of a tool that
# itself scans the whole system's open-file table each time -- easily slower
# than CLEAN_INTERVAL itself under load. INUSE_SET is built ONCE per cleanup
# pass instead, so checking a candidate afterward is an O(1) hash lookup.

declare -A INUSE_SET

build_inuse_index() {
    INUSE_SET=()

    if [ "$USE_LSOF" -eq 1 ]; then
        # -Fn: one 'n<path>' line per open file, one invocation total,
        # regardless of how many candidates we're about to check.
        local line
        while IFS= read -r line; do
            [ "${line:0:1}" = "n" ] && INUSE_SET["${line:1}"]=1
        done < <(lsof -Fn 2>/dev/null)
        return 0
    fi

    if [ "$USE_FUSER" -eq 1 ]; then
        # fuser has no reliable "list everything currently open" primitive to
        # batch against (its multi-file output isn't something to parse with
        # confidence across psmisc versions/locales), so this tier keeps the
        # original one-call-per-file check in is_file_in_use() below. This
        # path only matters on a system with fuser but no lsof; lsof is
        # essentially always present on a dev/gaming workstation, so the
        # fast path above is the one that actually matters in practice.
        return 0
    fi

    # No lsof, no fuser: resolve every /proc/*/fd symlink with ONE batched
    # readlink call instead of forking readlink separately per fd.
    local fds=(/proc/[0-9]*/fd/*)
    [ -e "${fds[0]}" ] || return 0
    local target
    while IFS= read -r target; do
        [ -n "$target" ] && INUSE_SET["$target"]=1
    done < <(readlink -f -- "${fds[@]}" 2>/dev/null)
}

is_file_in_use() {
    local file="$1"
    [ -e "$file" ] || return 1

    if [ "$USE_FUSER" -eq 1 ] && [ "$USE_LSOF" -ne 1 ]; then
        fuser -s -- "$file" >/dev/null 2>&1
        return $?
    fi

    local real
    real="$(readlink -f -- "$file" 2>/dev/null)" || real="$file"
    [ -n "${INUSE_SET[$real]+x}" ]
}

mount_tmpfs() {
    local dir="$1" size="$2" mode="$3"
    mkdir -p -- "$dir"
    if mountpoint -q -- "$dir"; then
        log "$dir already mounted, skipping."
        return 0
    fi
    log "Mounting tmpfs on $dir (size=$size mode=$mode)..."
    # noswap (kernel 6.3+) keeps this tmpfs's pages from being pushed to
    # swap under memory pressure -- without it, a "RAM-backed" directory can
    # silently start costing swap I/O, which is worse than not having the
    # overlay at all. Falls back cleanly on older kernels.
    if mount -t tmpfs -o "size=${size},mode=${mode},noswap" none "$dir" 2>/dev/null; then
        return 0
    fi
    if mount -t tmpfs -o "size=${size},mode=${mode}" none "$dir"; then
        return 0
    fi
    log "ERROR: Failed to mount tmpfs on $dir"
    return 1
}

# Moves any pre-existing content at $parent/$d into $PERSIST_ROOT/$parent/$d,
# for each $d in the given list. MUST be called BEFORE $parent is covered by
# a tmpfs mount: once tmpfs is mounted over $parent, the real on-disk content
# is masked, so this function would see an empty directory and never migrate
# anything. (This was a real bug: migration used to run after the tmpfs
# mount was already in place over /var/cache and each user's ~/.cache, so it
# silently never fired -- pre-existing pacman cache, and more importantly
# nvidia/mesa shader caches, were masked rather than migrated on first run.)
migrate_to_persist() {
    local parent="$1"
    shift
    local dirs=("$@")
    local persist_root="${PERSIST_ROOT}${parent}"
    mkdir -p "$persist_root" || { log "ERROR: failed to mkdir $persist_root"; return 1; }

    local d
    for d in "${dirs[@]}"; do
        local src="$persist_root/$d"
        local dest="$parent/$d"

        if [ -d "$dest" ] && [ ! -e "$src" ] && [ -n "$(ls -A "$dest" 2>/dev/null || true)" ]; then
            log "Moving existing $dest -> $src (first-run persistence)"
            mkdir -p "$(dirname "$src")"
            if command -v rsync >/dev/null 2>&1; then
                $RSYNC -a --remove-source-files "$dest"/ "$src"/ || true
                $FIND "$dest" -mindepth 1 -type d -empty -delete || true
            else
                mv "$dest" "$src" || true
            fi
        fi
    done
}

# Bind-mounts $PERSIST_ROOT/$parent/$d onto $parent/$d for each $d. Call
# AFTER $parent has been tmpfs-mounted (and after migrate_to_persist has
# already run against the real, pre-tmpfs $parent).
bind_persist_dirs() {
    local parent="$1"
    shift
    local dirs=("$@")
    local persist_root="${PERSIST_ROOT}${parent}"

    local d
    for d in "${dirs[@]}"; do
        local src="$persist_root/$d"
        local dest="$parent/$d"

        mkdir -p "$src" "$dest"

        if ! mountpoint -q "$dest"; then
            if mount --bind "$src" "$dest"; then
                log "Bind-mounted $src -> $dest"
            else
                log "ERROR: Failed to bind-mount $src -> $dest"
            fi
        else
            log "$dest already a mountpoint, skipping bind."
        fi
    done
}

mount_user_caches() {
    local users
    users=$(getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 && $6 ~ /^\/home\// { print $1 ":" $6 }')
    while IFS=: read -r username homedir; do
        if [ -z "$username" ] || [ -z "$homedir" ]; then continue; fi
        [ -d "$homedir" ] || continue
        local cache_dir="$homedir/.cache"
        local user_stat
        user_stat=$(stat -c "%u:%g" "$homedir" 2>/dev/null) || continue
        local uid=${user_stat%:*}
        local gid=${user_stat#*:}

        if [ ! -d "$cache_dir" ]; then
            mkdir -p "$cache_dir"
            chown "${uid}:${gid}" "$cache_dir"
            chmod 0700 "$cache_dir"
        fi

        if mountpoint -q -- "$cache_dir"; then
            log "$cache_dir already mounted, skipping."
            continue
        fi

        # Migrate pre-existing driver/shader caches BEFORE the tmpfs mount
        # below would otherwise mask them (see migrate_to_persist notes).
        migrate_to_persist "$cache_dir" "${BIND_MOUNTED_USER_CACHE[@]}"

        log "Mounting tmpfs on $cache_dir (size=$USER_CACHE_SIZE) for $username..."
        if ! mount -t tmpfs -o "size=${USER_CACHE_SIZE},mode=0700,uid=${uid},gid=${gid},noswap" none "$cache_dir" 2>/dev/null; then
            if ! mount -t tmpfs -o "size=${USER_CACHE_SIZE},mode=0700,uid=${uid},gid=${gid}" none "$cache_dir"; then
                log "ERROR: Failed to mount tmpfs cache for $username - leaving ~/.cache on disk"
                continue
            fi
        fi

        bind_persist_dirs "$cache_dir" "${BIND_MOUNTED_USER_CACHE[@]}"

        chown "${uid}:${gid}" "$cache_dir" || true
        local subdir
        for subdir in "${BIND_MOUNTED_USER_CACHE[@]}"; do
            local d="$cache_dir/$subdir"
            if [ -d "$d" ]; then
                local cur_owner
                cur_owner=$(stat -c "%u:%g" "$d" 2>/dev/null) || cur_owner=""
                # Skip the recursive walk when ownership is already correct
                # -- shader caches can be large, and chown -R over them on
                # every login when nothing needs changing is wasted work.
                if [ "$cur_owner" != "${uid}:${gid}" ]; then
                    chown -R "${uid}:${gid}" "$d" || true
                fi
            fi
        done
    done <<< "$users"
}

umount_try() {
    local dir="$1"
    [ ! -d "$dir" ] && return 0
    if ! mountpoint -q -- "$dir"; then return 0; fi

    log "Attempting normal umount $dir..."
    if umount "$dir" 2>/dev/null; then log "Unmounted $dir (normal)"; return 0; fi
    log "Normal umount failed; trying force..."
    if umount -f "$dir" 2>/dev/null; then log "Unmounted $dir (force)"; return 0; fi
    log "Force umount failed; trying lazy..."
    if umount -l "$dir" 2>/dev/null; then log "Unmounted $dir (lazy)"; return 0; fi
    log "All umount attempts failed for $dir."
    return 1
}

umount_user_caches() {
    local users
    users=$(getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 && $6 ~ /^\/home\// { print $6 }')
    while read -r homedir; do
        if [ -z "$homedir" ] || [ ! -d "$homedir" ]; then continue; fi
        local cache_dir="$homedir/.cache"
        for ((i=${#BIND_MOUNTED_USER_CACHE[@]}-1; i>=0; i--)); do
            umount_try "$cache_dir/${BIND_MOUNTED_USER_CACHE[i]}" || true
        done
        umount_try "$cache_dir" || true
    done <<< "$users"
}

umount_var_cache() {
    for ((i=${#BIND_MOUNTED_VAR_CACHE[@]}-1; i>=0; i--)); do
        umount_try "/var/cache/${BIND_MOUNTED_VAR_CACHE[i]}" || true
    done
    umount_try /var/cache || true
}

cleanup_stale_files() {
    local var_cache_excludes=()
    local vcdir
    for vcdir in "${BIND_MOUNTED_VAR_CACHE[@]}"; do
        var_cache_excludes+=("/var/cache/$vcdir")
    done

    # Phase 1: collect every stale-by-mtime candidate first, with NO in-use
    # check yet -- that happens once, in bulk, in phase 2.
    local candidates=()

    local dir
    for dir in /tmp /var/tmp; do
        [ -d "$dir" ] || continue
        while IFS= read -r -d '' file; do
            candidates+=("$file")
        done < <($FIND "$dir" -mindepth 1 -type f -mmin +"$STALE_MINUTES" -print0 2>/dev/null)
    done

    if [ -d /var/cache ]; then
        while IFS= read -r -d '' file; do
            local excluded=0
            local ex
            for ex in "${var_cache_excludes[@]}"; do
                if [[ "$file" == "$ex"* ]]; then
                    excluded=1
                    break
                fi
            done
            [ $excluded -eq 0 ] && candidates+=("$file")
        done < <($FIND /var/cache -mindepth 1 -type f -mmin +"$STALE_MINUTES" -print0 2>/dev/null)
    fi

    local users
    users=$(getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 && $6 ~ /^\/home\// { print $6 }')
    while read -r homedir; do
        if [ -z "$homedir" ] || [ ! -d "$homedir" ]; then continue; fi
        local cache_dir="$homedir/.cache"
        [ -d "$cache_dir" ] || continue

        while IFS= read -r -d '' file; do
            local skip=0
            local bd
            for bd in "${BIND_MOUNTED_USER_CACHE[@]}"; do
                if [[ "$file" == "$cache_dir/$bd"* ]]; then
                    skip=1
                    break
                fi
            done
            [ $skip -eq 0 ] && candidates+=("$file")
        done < <($FIND "$cache_dir" -mindepth 1 -type f -mmin +"$STALE_MINUTES" -print0 2>/dev/null)
    done <<< "$users"

    [ ${#candidates[@]} -eq 0 ] && return 0

    # Phase 2: ONE pass to learn which candidates are open, instead of
    # forking lsof/fuser (or walking all of /proc) once per candidate.
    build_inuse_index

    local files_to_delete=()
    local file
    for file in "${candidates[@]}"; do
        if is_file_in_use "$file"; then
            log "Skipping in-use file: $file"
        else
            files_to_delete+=("$file")
        fi
    done

    # Phase 3: batch-delete, chunked via xargs so a very large batch can't
    # exceed ARG_MAX and silently delete nothing (a bare `rm -f "${arr[@]}"`
    # would fail outright on a big enough batch, and the failure was being
    # swallowed by `|| true` -- exactly the case the batching was meant to
    # help with).
    if [ ${#files_to_delete[@]} -gt 0 ]; then
        log "Deleting ${#files_to_delete[@]} stale files..."
        printf '%s\0' "${files_to_delete[@]}" | xargs -0 -r rm -f -- 2>/dev/null || true
        log "Cleanup complete"
    fi
}

start_inotify_watcher() {
    if ! command -v inotifywait >/dev/null 2>&1; then
        log "inotifywait not available - incremental sync disabled, using full rsync"
        return 0
    fi

    # Collect upper dirs that actually exist
    local watch_dirs=()
    local dir
    for dir in "${OVERLAY_DIRS[@]}"; do
        local upper="$OVERLAY_BASE/upper${dir}"
        mkdir -p "$upper"
        watch_dirs+=("$upper")
    done

    [ ${#watch_dirs[@]} -eq 0 ] && return 0

    # Start fresh queue
    : > "$INOTIFY_QUEUE"

    # Watch for all write-side events; output absolute path per line
    $INOTIFYWAIT -m -r \
        -e modify,create,delete,moved_to,moved_from \
        --format '%w%f' \
        "${watch_dirs[@]}" >> "$INOTIFY_QUEUE" 2>/dev/null &

    echo $! > "$INOTIFY_PIDFILE"
    log "inotify watcher started (PID: $!) tracking ${#watch_dirs[@]} upper dir(s)"
}

stop_inotify_watcher() {
    if [ -f "$INOTIFY_PIDFILE" ]; then
        local pid
        pid=$(cat "$INOTIFY_PIDFILE")
        kill "$pid" 2>/dev/null || true
        wait "$pid" 2>/dev/null || true
        rm -f "$INOTIFY_PIDFILE" "$INOTIFY_QUEUE"
        log "inotify watcher stopped"
    fi
}

start_tmpfs_mounts() {
    log "Starting tmpfs mounts..."

    mkdir -p "$PERSIST_ROOT"

    # Migrate pre-existing content BEFORE mount_tmpfs below hides it.
    migrate_to_persist /var/cache "${BIND_MOUNTED_VAR_CACHE[@]}"

    mount_tmpfs /tmp "$TMP_SIZE" 1777 || log "WARNING: /tmp will remain on disk"
    mount_tmpfs /var/tmp "$VAR_TMP_SIZE" 1777 || log "WARNING: /var/tmp will remain on disk"
    mount_tmpfs /var/cache "$VAR_CACHE_SIZE" 0755 || log "WARNING: /var/cache will remain on disk"

    bind_persist_dirs /var/cache "${BIND_MOUNTED_VAR_CACHE[@]}"
    mount_user_caches

    log "tmpfs mounts completed."
}

stop_tmpfs_mounts() {
    log "Stopping tmpfs mounts..."
    log "Syncing filesystem..."
    sync

    umount_user_caches
    umount_var_cache
    umount_try /var/tmp || true
    umount_try /tmp || true

    log "tmpfs mounts stopped."
}

create_overlay_base() {
    log "Creating RAM overlay base directory..."

    mkdir -p "$OVERLAY_BASE"

    if mountpoint -q "$OVERLAY_BASE"; then
        return 0
    fi

    if mount -t tmpfs -o "size=${OVERLAY_BASE_SIZE},mode=0755,noswap" tmpfs "$OVERLAY_BASE" 2>/dev/null; then
        log "Mounted tmpfs at $OVERLAY_BASE (size=$OVERLAY_BASE_SIZE of RAM)"
        return 0
    fi

    if mount -t tmpfs -o "size=${OVERLAY_BASE_SIZE},mode=0755" tmpfs "$OVERLAY_BASE"; then
        log "Mounted tmpfs at $OVERLAY_BASE (size=$OVERLAY_BASE_SIZE of RAM, noswap unsupported on this kernel)"
        return 0
    fi

    log "ERROR: Failed to mount tmpfs at $OVERLAY_BASE"
    return 1
}

create_directory_overlay() {
    local target_dir="$1"
    local prepopulate="${2:-1}"
    local dir_name upper_dir work_dir
    dir_name=$(echo "$target_dir" | tr '/' '_')
    upper_dir="$OVERLAY_BASE/upper${target_dir}"
    work_dir="$OVERLAY_BASE/work${target_dir}"

    # Create necessary directories for overlay mount
    mkdir -p "$upper_dir" "$work_dir"

    # Check if already mounted (findmnt does a single targeted lookup rather
    # than listing every mount and grepping it)
    if [ "$(findmnt -n -o FSTYPE --target "$target_dir" 2>/dev/null)" = "overlay" ]; then
        log "$target_dir already has overlay mounted, skipping"
        return 0
    fi

    if [ "$prepopulate" -eq 1 ]; then
        # Pre-populate the upper layer with the lower layer's contents before
        # mounting.
        #
        # Without this, overlayfs uses lazy copy-up: a file that exists only
        # in the lower layer is readable but returns EPERM on lstat() in
        # certain kernel/tool combinations (notably pacman's pre-write stat
        # check). This causes spurious "Could not stat" errors when
        # reinstalling packages whose config files were never modified (and
        # therefore never copy-up'd into the upper layer).
        #
        # --ignore-existing preserves any changes already in the upper layer
        # from a previous session that were synced back to disk and are now
        # in the lower layer. --archive preserves permissions, timestamps,
        # symlinks, and xattrs (-aAX). We intentionally skip --delete so
        # stale upper-layer entries are left in place (they are either valid
        # changes or harmless; the overlay will mask them anyway).
        #
        # EXCLUDED_FROM_SYNC paths are skipped here too: they're never
        # written back to disk by sync_changes, so eagerly copying them into
        # RAM on every first mount (e.g. the systemd journal under
        # /var/log) would burn RAM and time for data that can never
        # round-trip anyway. Anything under an excluded path that's actually
        # written during the session still gets copied up lazily by the
        # kernel's normal overlay copy-up path -- this just stops eagerly
        # bulk-copying it up front.
        local exclude_opts=()
        while IFS= read -r opt; do
            exclude_opts+=("$opt")
        done < <(compute_exclude_opts "$target_dir")

        log "Pre-populating upper layer for $target_dir (ensures full stat visibility)..."
        $RSYNC -aAX --ignore-existing "${exclude_opts[@]}" "$target_dir/" "$upper_dir/" 2>/dev/null || \
            log "WARNING: Pre-population rsync for $target_dir had errors (non-fatal)"
    fi

    # Create the overlay mount directly over the original directory
    # Lower layer: original disk directory (read-only via overlay)
    # Upper layer: RAM storage for all modifications
    # Work layer: overlay filesystem internal use
    log "Mounting overlay on $target_dir..."

    # Progressive fallback across mount-option support, oldest kernel last:
    #   1) metacopy=off + volatile (5.10+)
    #   2) metacopy=off only
    #   3) neither
    # volatile is a deliberate choice, not just a nice-to-have: upperdir is
    # tmpfs, which is never durable across a reboot regardless, so
    # overlayfs's own sync/fsync bookkeeping on that upperdir is protecting a
    # durability guarantee this setup never makes in the first place.
    # sync_changes() is what actually persists data (by rsyncing out to real
    # disk) and is untouched by this option.
    if mount -t overlay "overlay_${dir_name}" \
        -o "lowerdir=${target_dir},upperdir=${upper_dir},workdir=${work_dir},metacopy=off,volatile,noatime" \
        "$target_dir" 2>/dev/null; then
        log "Successfully mounted RAM overlay on $target_dir (metacopy=off, volatile)"
        return 0
    fi

    if mount -t overlay "overlay_${dir_name}" \
        -o "lowerdir=${target_dir},upperdir=${upper_dir},workdir=${work_dir},metacopy=off,noatime" \
        "$target_dir" 2>/dev/null; then
        log "Successfully mounted RAM overlay on $target_dir (metacopy=off, volatile unsupported)"
        return 0
    fi

    log "WARNING: Mount with metacopy=off failed, retrying without it..."
    if mount -t overlay "overlay_${dir_name}" \
        -o "lowerdir=${target_dir},upperdir=${upper_dir},workdir=${work_dir},noatime" \
        "$target_dir" 2>/dev/null; then
        log "Successfully mounted RAM overlay on $target_dir (metacopy not supported on this kernel)"
        return 0
    fi

    log "ERROR: Failed to mount overlay on $target_dir — writes will go directly to disk"
    return 1
}

start_overlay() {
    if is_active; then
        log "RAM overlay is already active"
        return 0
    fi

    log "Starting unified RAM overlay system..."

    start_tmpfs_mounts

    if ! create_overlay_base; then
        log "ERROR: Cannot create RAM overlay base - aborting overlay start (will retry on next login cycle)"
        return 1
    fi

    # Mount overlays on each specified directory
    local failed=0
    local dir
    for dir in "${OVERLAY_DIRS[@]}"; do
        if [ -d "$dir" ]; then
            create_directory_overlay "$dir" || {
                log "WARNING: Failed to create overlay for $dir"
                failed=$((failed + 1))
            }
        else
            log "WARNING: Directory $dir does not exist, skipping"
        fi
    done

    if [ $failed -gt 0 ]; then
        log "WARNING: $failed overlay(s) failed to mount — system running in degraded mode"
        echo "degraded" > "$STATE_FILE"
        echo "started=$(date +%s)" >> "$STATE_FILE"
    else
        echo "active" > "$STATE_FILE"
        echo "started=$(date +%s)" >> "$STATE_FILE"
    fi

    # Start incremental change tracking now that upper dirs exist
    start_inotify_watcher

    log "RAM overlay system started successfully"
    log "Overlaid directories: ${OVERLAY_DIRS[*]}"
    log "Changes are being stored in RAM at: $OVERLAY_BASE"

    df -h "$OVERLAY_BASE" 2>/dev/null | tail -1 | awk '{print "RAM allocated: " $2 " (Used: " $3 ", Available: " $4 ")"}'

    log "tmpfs cleanup loop starting (interval=${CLEAN_INTERVAL}s, stale>${STALE_MINUTES}m)."

    # Show what's actually overlaid
    log "Active overlay mounts:"
    findmnt -t overlay | tee -a "$LOG_FILE"
}

# Syncs RAM -> disk for every OVERLAY_DIRS entry, then remounts each overlay
# so the system keeps serving normally afterward.
#
# $1 (optional): force incremental (1) or full (0) mode. If omitted,
# auto-detects from whether the inotify watcher is currently alive. The
# explicit form exists because stop_overlay needs to request incremental
# mode AFTER it has already stopped the watcher (see notes there) --
# auto-detection alone would always say "no" at that point.
sync_changes() {
    local use_inotify="${1:-}"

    if ! is_active; then
        log "RAM overlay is not active, nothing to sync"
        return 0
    fi

    log "Syncing changes from RAM to disk..."

    local sync_dir_fail="/var/run/ramoverlay-syncfail"
    rm -f "${sync_dir_fail}".*

    if [ -z "$use_inotify" ]; then
        use_inotify=0
        [ -f "$INOTIFY_PIDFILE" ] && kill -0 "$(cat "$INOTIFY_PIDFILE")" 2>/dev/null && use_inotify=1
    fi

    # Rotate the shared inotify queue exactly ONCE, before any per-directory
    # parallel work starts, and have each directory's subshell below just
    # read-filter the resulting static snapshot. The previous version had
    # EACH per-directory subshell do this same mv-based rotation
    # independently; with 2+ OVERLAY_DIRS (the actual default: /etc and
    # /var/log) that's two concurrent renames racing on the same
    # $INOTIFY_QUEUE/$INOTIFY_QUEUE.snap paths, and the loser's `mv` fails
    # outright (source already moved by the winner) -- silently discarding
    # that directory's pending changes for the pass instead of syncing them.
    local snap="${INOTIFY_QUEUE}.snap"
    if [ "$use_inotify" -eq 1 ]; then
        if [ -s "$INOTIFY_QUEUE" ]; then
            mv "$INOTIFY_QUEUE" "$snap"
            : > "$INOTIFY_QUEUE"
        else
            log "No inotify-tracked changes since last sync, nothing to do"
            return 0
        fi
    fi

    for dir in "${OVERLAY_DIRS[@]}"; do
        (
            local upper_dir="$OVERLAY_BASE/upper${dir}"
            local fail_flag="${sync_dir_fail}.${dir//\//_}"

            if [ ! -d "$upper_dir" ] || [ -z "$(ls -A "$upper_dir" 2>/dev/null)" ]; then
                log "No changes in $dir, skipping"
                exit 0
            fi

            local exclude_opts=()
            while IFS= read -r opt; do
                exclude_opts+=("$opt")
            done < <(compute_exclude_opts "$dir")

            if [ "$use_inotify" -eq 1 ]; then
                local changed_files
                changed_files=$(grep -F "${upper_dir}/" "$snap" 2>/dev/null \
                    | sed "s|^${upper_dir}/||" \
                    | sort -u)

                if [ -z "$changed_files" ]; then
                    log "No inotify-tracked changes in $dir, skipping"
                    exit 0
                fi

                local count
                count=$(echo "$changed_files" | wc -l)
                log "Incremental sync of $dir ($count changed file(s) via inotify)..."

                # Unmount so rsync writes to real disk, not back into overlay
                if ! umount_try "$dir"; then
                    log "ERROR: Failed to unmount $dir for incremental sync"
                    touch "$fail_flag"
                    exit 1
                fi

                # Capture rsync's own exit code via PIPESTATUS rather than
                # `cmd || var=$?` in front of a pipe -- the left side of a
                # pipeline runs in its own subshell, so that assignment was
                # being thrown away every time, and rsync failures during
                # sync were never actually detected. (Static analysis flags
                # this pattern as SC2030/SC2031; that's how it turned up.)
                $RSYNC -aAXH "${exclude_opts[@]}" \
                    --files-from=<(echo "$changed_files") \
                    "$upper_dir/" "$dir/" 2>&1 | tee -a "$LOG_FILE"
                local rsync_ok=${PIPESTATUS[0]}

                if [ "$rsync_ok" -ne 0 ]; then
                    log "ERROR: Incremental rsync failed for $dir (exit $rsync_ok)"
                    touch "$fail_flag"
                else
                    log "Incremental sync of $dir complete"
                fi

                if ! create_directory_overlay "$dir" 0; then
                    log "ERROR: Failed to remount overlay on $dir after incremental sync"
                    touch "$fail_flag"
                fi
                exit 0
            fi

            # --- full rsync fallback ---
            log "Full sync of $dir (no inotify)..."
            if ! umount_try "$dir"; then
                log "ERROR: Failed to unmount $dir for syncing"
                touch "$fail_flag"
                exit 1
            fi

            $RSYNC -aAXHv "${exclude_opts[@]}" \
                "$upper_dir/" "$dir/" 2>&1 | tee -a "$LOG_FILE"
            local rsync_ok=${PIPESTATUS[0]}

            if [ "$rsync_ok" -eq 0 ]; then
                log "Successfully synced $dir"
            else
                log "ERROR: Failed to sync $dir (rsync exit code: $rsync_ok)"
                touch "$fail_flag"
            fi

            if ! create_directory_overlay "$dir" 0; then
                log "ERROR: Failed to remount overlay on $dir"
                touch "$fail_flag"
            fi
        ) &
    done

    # Wait for all parallel syncs to complete
    wait

    [ -f "$snap" ] && rm -f "$snap"

    sync

    # Count failures via flag files
    local sync_failed=0
    for dir in "${OVERLAY_DIRS[@]}"; do
        local fail_flag="${sync_dir_fail}.${dir//\//_}"
        if [ -f "$fail_flag" ]; then
            sync_failed=$((sync_failed + 1))
            rm -f "$fail_flag"
        fi
    done

    if [ "$sync_failed" -gt 0 ]; then
        log "WARNING: $sync_failed directory sync(s) failed"
        return 1
    else
        log "All changes synced successfully"
        return 0
    fi
}

stop_overlay() {
    if ! is_active; then
        log "RAM overlay is not active"
        stop_tmpfs_mounts
        return 0
    fi

    log "Stopping RAM overlay system..."

    # Snapshot whether the watcher was actually alive BEFORE stopping it, and
    # pass that into sync_changes explicitly. Previously stop_inotify_watcher
    # ran first and removed $INOTIFY_PIDFILE, so sync_changes's own "is the
    # watcher alive" check was always false by the time it ran here -- every
    # real sync silently fell back to a full-tree rsync of the entire
    # directory, and the inotify/queue machinery never actually engaged
    # despite being fully implemented.
    local had_watcher=0
    [ -f "$INOTIFY_PIDFILE" ] && kill -0 "$(cat "$INOTIFY_PIDFILE")" 2>/dev/null && had_watcher=1

    # Stop the watcher before syncing so the queue captures all remaining
    # events and nothing new arrives mid-sync.
    stop_inotify_watcher

    # sync_changes() is now the single place that copies RAM -> disk. The
    # old code did this here too, unconditionally and in full, immediately
    # after sync_changes had already done it (whether full or, once fixed,
    # incremental) -- every logout paid for two complete rsyncs of /etc and
    # /var/log back to back, and the second one didn't even honor
    # EXCLUDED_FROM_SYNC. sync_changes remounts each directory afterward;
    # the unmount loop below immediately undoes that, which is a
    # deliberately cheap no-op (one mount/unmount syscall pair) traded for
    # keeping sync_changes's "sync and keep serving" shape usable as-is for
    # the periodic mid-session sync in the main loop.
    sync_changes "$had_watcher"

    # Unmount overlays in reverse order
    log "Unmounting overlay filesystems..."
    for ((i=${#OVERLAY_DIRS[@]}-1; i>=0; i--)); do
        local dir="${OVERLAY_DIRS[i]}"
        umount_try "$dir" || log "ERROR: Failed to unmount $dir"
    done

    # Unmount the overlay base
    if mountpoint -q "$OVERLAY_BASE"; then
        log "Unmounting tmpfs and freeing RAM..."
        umount "$OVERLAY_BASE" || log "Warning: Failed to unmount tmpfs"
    fi

    rm -f "$STATE_FILE"

    stop_tmpfs_mounts

    log "RAM overlay system stopped - RAM freed"

    # Truncate log so next boot starts fresh — archive last session first
    # so the final shutdown messages are preserved if needed for debugging
    local archive="/var/log/ramoverlay.last.log"
    cp "$LOG_FILE" "$archive" 2>/dev/null || true
    : > "$LOG_FILE"
}

get_logged_in_users() {
    # More reliable user detection
    local count=0

    # Check who command
    count=$(who | awk '{print $1}' | sort -u | wc -l)

    # If no users from who, check for X sessions (count only sockets)
    if [ "$count" -eq 0 ] && [ -d /tmp/.X11-unix ]; then
        count=$(find /tmp/.X11-unix -maxdepth 1 -name 'X*' -type s 2>/dev/null | wc -l)
    fi

    echo "$count"
}

wait_for_login() {
    log "Waiting for user login..."

    while true; do
        local users
        users=$(get_logged_in_users)

        if [ "$users" -gt 0 ]; then
            log "User login detected ($users users)"
            return 0
        fi

        sleep 5
    done
}

CLEANUP_DONE=0

shutdown_cleanup() {
    # Guard against running twice: this fires once for whatever signal
    # triggered it, and then again as part of ITS OWN `exit` below (since
    # EXIT is also trapped, so any exit path -- including one caused by an
    # unguarded command failing under `set -e` elsewhere -- still triggers a
    # sync instead of silently dropping whatever's only in the RAM overlay).
    [ "$CLEANUP_DONE" -eq 1 ] && exit 0
    CLEANUP_DONE=1

    log "Shutdown/reboot signal received - syncing all changes to disk..."
    stop_overlay
    rm -f "$DAEMON_PIDFILE"
    log "Shutdown sync complete - exiting"
    exit 0
}

check_root

if [ -f "$DAEMON_PIDFILE" ] && kill -0 "$(cat "$DAEMON_PIDFILE")" 2>/dev/null; then
    log "Already running with PID $(cat "$DAEMON_PIDFILE") - exiting"
    exit 0
fi

echo $$ > "$DAEMON_PIDFILE"

mkdir -p "$(dirname "$LOG_FILE")"
touch "$LOG_FILE" || true

log "Unified RAM overlay daemon started (PID: $$)"
log "Overlay directories: ${OVERLAY_DIRS[*]}"
if [ "$USE_LSOF" -eq 1 ]; then
    log "Using lsof to detect open files (batched once per cleanup pass)"
elif [ "$USE_FUSER" -eq 1 ]; then
    log "Using fuser to detect open files (per-file check; install lsof for a faster batched check)"
else
    log "Using /proc fallback to detect open files (batched once per cleanup pass)"
fi

trap shutdown_cleanup EXIT SIGTERM SIGINT SIGHUP

while true; do
    wait_for_login

    sleep 3

    log "Starting RAM overlay system..."
    if start_overlay; then
        if is_degraded; then
            log "WARNING: RAM overlay started in DEGRADED mode — one or more overlays failed to mount"
            log "Writes to failed directories are going directly to disk"
        else
            log "RAM overlay started successfully"
            log "System is now running with RAM-backed directories"
            log "Check 'findmnt -t overlay' to see active overlays"
        fi
    else
        log "ERROR: Failed to start RAM overlay - will retry on next login"
        sleep 5
        continue
    fi

    elapsed_since_sync=0
    while [ "$(get_logged_in_users)" -gt 0 ]; do
        sleep "$CLEAN_INTERVAL"
        cleanup_stale_files

        if [ "$SYNC_INTERVAL" -gt 0 ]; then
            elapsed_since_sync=$((elapsed_since_sync + CLEAN_INTERVAL))
            if [ "$elapsed_since_sync" -ge "$SYNC_INTERVAL" ]; then
                elapsed_since_sync=0
                watcher_alive=0
                [ -f "$INOTIFY_PIDFILE" ] && kill -0 "$(cat "$INOTIFY_PIDFILE")" 2>/dev/null && watcher_alive=1
                log "Periodic sync (interval=${SYNC_INTERVAL}s)..."
                sync_changes "$watcher_alive" || log "WARNING: periodic sync reported failures"
            fi
        fi
    done

    log "All users logged out - initiating shutdown sequence"

    sleep 2

    log "Stopping and syncing RAM overlay..."
    if stop_overlay; then
        log "RAM overlay stopped and synced successfully"
    else
        log "ERROR: Issues during RAM overlay shutdown"
    fi

    log "System ready for next login cycle"

    sleep 5
done
